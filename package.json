{
  "name": "xcvzmoon-tauri-starter",
  "description": "My starter for Tauri template with Nuxt",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "author": "Mon Albert Gamil <mrgamilmonalbert@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcvzmoon/tauri-starter.git"
  },
  "scripts": {
    "build": "bunx --bun nuxt build",
    "dev": "bunx --bun nuxt dev",
    "generate": "bunx --bun nuxt generate",
    "preview": "bunx --bun nuxt preview",
    "postinstall": "bunx --bun nuxt prepare",
    "typecheck": "bunx --bun nuxt typecheck",
    "fmt": "run-p fmt:nuxt fmt:tauri",
    "fmt:nuxt": "oxfmt && oxfmt --check",
    "fmt:tauri": "cd src-tauri && cargo fmt",
    "lint": "oxlint",
    "prepare": "husky",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "release:patch": "changelogen --patch --bump && bun run release:finish",
    "release:minor": "changelogen --minor --bump && bun run release:finish",
    "release:major": "changelogen --major --bump && bun run release:finish",
    "release:dry": "changelogen --dry",
    "release:finish": "run-s sync:tauri-version release:commit release:push",
    "release:commit": "bun scripts/create-release-commit.ts",
    "release:push": "git push --follow-tags",
    "sync:tauri-version": "bun scripts/sync-tauri-version.ts"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/hints": "1.1.2",
    "@nuxt/ui": "4.8.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.6",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.10",
    "changelogen": "^0.6.2",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright-core": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,html,css,yml,yaml}": "oxfmt",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@latest"
  },
  "packageManager": "bun@1.3.14"
}
